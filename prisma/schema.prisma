model PayrollExportLine {
  id                   String             @id @default(cuid())
  payrollExportBatchId String
  staffMemberId        String
  externalEmployeeRef  String?
  grossTipsAmount      Decimal            @db.Decimal(10, 2)
  hoursWorked          Decimal?           @db.Decimal(8, 2)
  serviceChargeAmount  Decimal?           @db.Decimal(10, 2)
  netPayableAmount     Decimal?           @db.Decimal(10, 2)
  currency             String             @default("GBP")
  linePayload          Json?
  payrollExportBatch   PayrollExportBatch @relation(fields: [payrollExportBatchId], references: [id], onDelete: Cascade)
  staffMember          StaffMember        @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([payrollExportBatchId, staffMemberId])
  @@index([staffMemberId, createdAt])
  @@index([externalEmployeeRef])
}

model TipOutRule {
    id                       String      @id @default(cuid())
    customerId               String
    scope                    TipOutRuleScope @default(VENUE)
    venueId                  String?
    departmentId             String?
    targetPoolId             String
    name                     String
    description              String?
    rateDecimal              Decimal     @db.Decimal(8, 6)
  capAtAvailableTipBalance Boolean     @default(true)
  isActive                 Boolean     @default(true)
    effectiveFrom            DateTime?
    effectiveTo              DateTime?
    customer                 Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
    venue                    Venue?      @relation(fields: [venueId], references: [id], onDelete: Cascade)
    department               Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
    targetPool               Pool        @relation(fields: [targetPoolId], references: [id], onDelete: Restrict)
    tipOutPostings           TipOutPosting[]
    createdAt                DateTime    @default(now())
    updatedAt                DateTime    @updatedAt
  
    @@index([customerId, isActive])
    @@index([scope, customerId, isActive])
    @@index([venueId, isActive])
    @@index([departmentId, isActive])
    @@index([targetPoolId, isActive])
    @@index([venueId, departmentId, isActive])
  }

model TipOutPosting {
  id                        String                @id @default(cuid())
  customerId                String
  venueId                   String
  departmentId              String?
  payrollPeriodId           String?
  tipOutRuleId              String
  targetPoolId              String
  staffMemberId             String
  importedServiceChargeId   String?
  businessDate              DateTime
  totalSalesAmount          Decimal               @db.Decimal(10, 2)
  discountsAmount           Decimal               @db.Decimal(10, 2)
  netSalesAmount            Decimal               @db.Decimal(10, 2)
  availableTipBalanceAmount Decimal               @db.Decimal(10, 2)
  tipOutRateDecimal         Decimal               @db.Decimal(8, 6)
  requestedTipOutAmount     Decimal               @db.Decimal(10, 2)
  tipOutAmount              Decimal               @db.Decimal(10, 2)
  remainingTipBalanceAmount Decimal               @db.Decimal(10, 2)
  wasCapped                 Boolean               @default(false)
  customer                  Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue                     Venue                 @relation(fields: [venueId], references: [id], onDelete: Cascade)
  department                Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  payrollPeriod             PayrollPeriod?        @relation(fields: [payrollPeriodId], references: [id], onDelete: SetNull)
  tipOutRule                TipOutRule            @relation(fields: [tipOutRuleId], references: [id], onDelete: Cascade)
  targetPool                Pool                  @relation(fields: [targetPoolId], references: [id], onDelete: Restrict)
  staffMember               StaffMember           @relation(fields: [staffMemberId], references: [id], onDelete: Restrict)
  importedServiceCharge     ImportedServiceCharge? @relation(fields: [importedServiceChargeId], references: [id], onDelete: SetNull)
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt

  @@index([customerId, businessDate])
  @@index([venueId, businessDate])
  @@index([departmentId, businessDate])
  @@index([payrollPeriodId, targetPoolId])
  @@index([staffMemberId, businessDate])
  @@index([targetPoolId, businessDate])
  @@index([tipOutRuleId, businessDate])
}

model TipTransaction {
  id                    String               @id @default(cuid())
  customerId            String
  venueId               String
  payrollPeriodId       String?
  qrCodeSlug            String?
  destinationType       QrDestinationType
  destinationEmployeeId String?
  destinationPoolId     String?
  destinationVenueId    String?
  destinationServiceAreaId String?
  guestSelectionType    TipSelectionType?
  currency              String
  grossAmount           Decimal              @db.Decimal(10, 2)
  tipitFeeAmount        Decimal              @db.Decimal(10, 2)
  netAmount             Decimal              @db.Decimal(10, 2)
  status                TipTransactionStatus @default(PENDING)
  rating                Int?
  comment               String?
  ratedAt               DateTime?
  reviewIntegrationStatus ReviewIntegrationStatus @default(NOT_REQUESTED)
  occurredAt            DateTime
  stripeCheckoutId      String?
  customer              Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue                 Venue                @relation("VenueTipTransactions", fields: [venueId], references: [id], onDelete: Cascade)
  payrollPeriod         PayrollPeriod?       @relation(fields: [payrollPeriodId], references: [id], onDelete: SetNull)
  destinationEmployee   StaffMember?         @relation("TipDestinationEmployee", fields: [destinationEmployeeId], references: [id], onDelete: SetNull)
  destinationPool       Pool?                @relation("TipDestinationPool", fields: [destinationPoolId], references: [id], onDelete: SetNull)
  destinationVenue      Venue?               @relation("TipDestinationVenue", fields: [destinationVenueId], references: [id], onDelete: SetNull)
  destinationServiceArea ServiceArea?        @relation("TipDestinationServiceArea", fields: [destinationServiceAreaId], references: [id], onDelete: SetNull)
  allocationResults     AllocationResult[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([customerId, occurredAt])
  @@index([venueId, occurredAt])
  @@index([payrollPeriodId])
  @@index([status, occurredAt])
  @@index([destinationEmployeeId])
  @@index([destinationPoolId])
  @@index([destinationServiceAreaId])
  @@index([guestSelectionType, occurredAt])
  @@index([reviewIntegrationStatus, occurredAt])
}

model AllocationResult {
  id              String         @id @default(cuid())
  customerId      String
  venueId         String
  payrollPeriodId String?
  tipTransactionId String
  employeeId      String
  poolId          String?
  grossAmount     Decimal        @db.Decimal(10, 2)
  netAmount       Decimal        @db.Decimal(10, 2)
  customer        Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue           Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  payrollPeriod   PayrollPeriod? @relation(fields: [payrollPeriodId], references: [id], onDelete: SetNull)
  tipTransaction  TipTransaction @relation(fields: [tipTransactionId], references: [id], onDelete: Cascade)
  employee        StaffMember    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  pool            Pool?          @relation(fields: [poolId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([customerId, venueId])
  @@index([payrollPeriodId])
  @@index([tipTransactionId])
  @@index([employeeId])
  @@index([poolId])
}

model AuditLog {
  id                  String         @id @default(cuid())
  userId              String?
  customerId          String?
  customerUserId      String?
  venueId             String?
  staffMemberId       String?
  poolId              String?
  allocationRuleId    String?
  entityType          String
  entityId            String
  action              String
  summary             String?
  beforeData          Json?
  afterData           Json?
  metadata            Json?
  ipAddress           String?
  userAgent           String?
  user                User?          @relation("AuditActor", fields: [userId], references: [id], onDelete: SetNull)
  customer            Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerUser        CustomerUser?  @relation("AuditImpersonatedCustomerUser", fields: [customerUserId], references: [id], onDelete: SetNull)
  venue               Venue?         @relation("AuditVenue", fields: [venueId], references: [id], onDelete: SetNull)
  staffMember         StaffMember?   @relation("AuditStaffMember", fields: [staffMemberId], references: [id], onDelete: SetNull)
  pool                Pool?          @relation("AuditPool", fields: [poolId], references: [id], onDelete: SetNull)
  allocationRule      AllocationRule? @relation("AuditAllocationRule", fields: [allocationRuleId], references: [id], onDelete: SetNull)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  /// Audit rows are append-only in practice, even though updatedAt exists for consistency across main entities.
  @@index([userId, createdAt])
  @@index([customerId, createdAt])
  @@index([customerUserId, createdAt])
  @@index([venueId, createdAt])
  @@index([staffMemberId, createdAt])
  @@index([poolId, createdAt])
  @@index([allocationRuleId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
}
