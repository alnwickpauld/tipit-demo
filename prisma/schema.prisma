generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  TIPIT_ADMIN
  CUSTOMER_ADMIN
  CUSTOMER_MANAGER
  CUSTOMER_VIEWER
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VenueStatus {
  ACTIVE
  INACTIVE
}

enum VenueType {
  HOTEL_BAR
  RESTAURANT
  CAFE
  HOSPITALITY_SUITE
  EVENT_SPACE
  OTHER
}

enum RevenueCentreType {
  RESTAURANT
  BAR
  MEETINGS_EVENTS
  BREAKFAST
  ROOM_SERVICE
}

enum TippingMode {
  TEAM_ONLY
  INDIVIDUAL_ONLY
  TEAM_OR_INDIVIDUAL
  SHIFT_SELECTOR
}

enum DisplayMode {
  FIXED_SIGN
  TABLE_CARD
  BILL_FOLDER
  COUNTER_SIGN
  EVENT_SIGN
  OTHER
}

enum NoActiveShiftBehavior {
  DISABLE_INDIVIDUAL
  FALLBACK_TO_TEAM
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

enum PoolStatus {
  ACTIVE
  INACTIVE
}

enum PoolType {
  FOH
  BOH
  HYBRID
}

enum AllocationRecipientType {
  STAFF
  POOL
  SELECTED_STAFF
}

enum TipSelectionType {
  TEAM
  INDIVIDUAL
}

enum AllocationRuleScope {
  VENUE_DEFAULT
  DEPARTMENT
  SERVICE_AREA
}

enum TipOutRuleScope {
  CUSTOMER
  VENUE
  DEPARTMENT
}

enum QrDestinationType {
  EMPLOYEE
  POOL
  VENUE
  SERVICE_AREA
}

enum QrAssetDestinationType {
  SERVICE_AREA
  TEAM
  STAFF_MEMBER
}

enum PayrollFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
}

enum TipTransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum ReviewIntegrationStatus {
  NOT_REQUESTED
  ELIGIBLE
  PROMPTED
  COMPLETED
}

enum SettlementFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
}

enum ShiftStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum IntegrationProvider {
  ORACLE_SIMPHONY
  AMEEGO
  PLANET
  SAGE
  OTHER
}

enum IntegrationSyncStatus {
  PENDING
  SUCCEEDED
  FAILED
  PARTIAL
}

enum PayrollExportBatchStatus {
  DRAFT
  READY
  EXPORTED
  FAILED
  CANCELLED
}

enum PoolHoursEntrySource {
  MANUAL
  CSV_IMPORT
  INTEGRATION
}

enum PoolHoursEntryStatus {
  DRAFT
  LOCKED
}

enum PoolDistributionRunStatus {
  DRAFT
  READY_FOR_REVIEW
  LOCKED
  EXPORTED
}

model Role {
  id            String         @id @default(cuid())
  code          UserRole       @unique
  name          String
  description   String?
  users         User[]         @relation("PlatformRole")
  customerUsers CustomerUser[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  passwordHash      String
  firstName         String
  lastName          String
  isActive          Boolean        @default(true)
  lastLoginAt       DateTime?
  platformRoleId    String?
  platformRole      Role?          @relation("PlatformRole", fields: [platformRoleId], references: [id], onDelete: SetNull)
  customerUser      CustomerUser?
  auditLogs         AuditLog[]     @relation("AuditActor")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([isActive])
  @@index([platformRoleId])
  @@index([lastName, firstName])
}

model Customer {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  legalName      String?
  contactEmail   String
  contactPhone   String?
  status         CustomerStatus  @default(ACTIVE)
  tipitFeeBps    Int             @default(500)
  currency       String          @default("GBP")
  timezone       String          @default("Europe/London")
  venues         Venue[]
  outletBrands   OutletBrand[]
  departments    Department[]
  departmentTippingSettings CustomerDepartmentTippingSetting[]
  departmentStaffAssignments DepartmentStaffAssignment[]
  shifts         Shift[]
  serviceAreas   ServiceArea[]
  qrAssets       QrAsset[]
  staffMembers   StaffMember[]
  pools          Pool[]
  importedHoursWorked ImportedHoursWorked[]
  importedServiceCharges ImportedServiceCharge[]
  payrollExportBatches PayrollExportBatch[]
  payrollPeriods PayrollPeriod[]
  poolHoursEntries PoolHoursEntry[]
  poolDistributionRuns PoolDistributionRun[]
  poolDistributionAllocations PoolDistributionAllocation[]
  tipTransactions TipTransaction[]
  allocationResults AllocationResult[]
  tipOutRules    TipOutRule[]
  tipOutPostings TipOutPosting[]
  customerUsers  CustomerUser[]
  payrollConfig  PayrollConfig?
  payrollCalendar PayrollCalendar?
  auditLogs      AuditLog[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([name, contactEmail])
  @@index([status])
  @@index([name])
}

model CustomerUser {
  id            String     @id @default(cuid())
  customerId    String
  userId        String     @unique
  roleId        String
  isActive      Boolean    @default(true)
  customer      Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  auditLogs     AuditLog[] @relation("AuditImpersonatedCustomerUser")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  /// Customer-admin users must belong to exactly one customer, enforced by the unique userId.
  @@unique([customerId, userId])
  @@index([customerId, roleId])
  @@index([customerId, isActive])
}

model Venue {
  id              String           @id @default(cuid())
  customerId      String
  name            String
  slug            String
  code            String?
  externalSystemRef String?
  externalSystemProvider IntegrationProvider?
  type            VenueType?
  description     String?
  address         String?
  timezone        String?
  status          VenueStatus      @default(ACTIVE)
  addressLine1    String?
  addressLine2    String?
  city            String?
  postcode        String?
  country         String?
  brandBackgroundColor String      @default("#ECECEC")
  brandTextColor       String      @default("#111111")
  brandButtonColor     String      @default("#000000")
  brandButtonTextColor String      @default("#FFFFFF")
  brandLogoImageUrl    String?
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  outletBrands    OutletBrand[]
  departments     Department[]
  departmentStaffAssignments DepartmentStaffAssignment[]
  shifts          Shift[]
  serviceAreas    ServiceArea[]
  qrAssets        QrAsset[]
  importedHoursWorked ImportedHoursWorked[]
  importedServiceCharges ImportedServiceCharge[]
  payrollExportBatches PayrollExportBatch[]
  poolHoursEntries PoolHoursEntry[]
  poolDistributionRuns PoolDistributionRun[]
  poolDistributionAllocations PoolDistributionAllocation[]
  staffMembers    StaffMember[]
  pools           Pool[]
  allocationRules AllocationRule[]
  tipOutRules     TipOutRule[]
  tipOutPostings  TipOutPosting[]
  tipTransactions TipTransaction[]  @relation("VenueTipTransactions")
  destinationTipTransactions TipTransaction[] @relation("TipDestinationVenue")
  allocationResults AllocationResult[]
  auditLogs       AuditLog[]        @relation("AuditVenue")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([customerId, slug])
  @@unique([customerId, code])
  @@index([customerId, status])
  @@index([customerId, name])
  @@index([customerId, type])
  @@index([externalSystemProvider, externalSystemRef])
}

model OutletBrand {
  id            String     @id @default(cuid())
  customerId    String
  venueId       String
  name          String
  displayName   String
  logoUrl       String?
  customer      Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue         Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  departments   Department[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([venueId, name])
  @@index([customerId, venueId])
  @@index([venueId, displayName])
}

model Department {
  id            String         @id @default(cuid())
  customerId    String
  venueId       String
  outletBrandId String
  name          String
  slug          String
  revenueCentreType RevenueCentreType @default(RESTAURANT)
  description   String?
  externalSystemRef String?
  externalSystemProvider IntegrationProvider?
  isActive      Boolean        @default(true)
  customer      Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue         Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  outletBrand   OutletBrand    @relation(fields: [outletBrandId], references: [id], onDelete: Restrict)
  staffAssignments DepartmentStaffAssignment[]
  shifts        Shift[]
  serviceAreas  ServiceArea[]
  qrAssets      QrAsset[]
  importedHoursWorked ImportedHoursWorked[]
  importedServiceCharges ImportedServiceCharge[]
  allocationRules AllocationRule[]
  tipOutRules   TipOutRule[]
  tipOutPostings TipOutPosting[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([venueId, slug])
  @@index([customerId, venueId])
  @@index([outletBrandId])
  @@index([venueId, revenueCentreType, isActive])
  @@index([venueId, name])
  @@index([externalSystemProvider, externalSystemRef])
}

model ServiceArea {
  id                      String         @id @default(cuid())
  customerId              String
  venueId                 String
  departmentId            String
  name                    String
  slug                    String
  description             String?
  tipScreenBackgroundColor String?
  tipScreenTextColor       String?
  tipScreenButtonColor     String?
  tipScreenButtonTextColor String?
  tipScreenLogoImageUrl    String?
  tippingMode             TippingMode
  displayMode             DisplayMode
  noActiveShiftBehavior   NoActiveShiftBehavior @default(FALLBACK_TO_TEAM)
  teamTippingEnabled      Boolean        @default(true)
  individualTippingEnabled Boolean       @default(false)
  isActive                Boolean        @default(true)
  customer                Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue                   Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  department              Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  qrAssets                QrAsset[]
  importedServiceCharges  ImportedServiceCharge[]
  allocationRules         AllocationRule[]
  destinationTipTransactions TipTransaction[] @relation("TipDestinationServiceArea")
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  @@unique([venueId, slug])
  @@index([customerId, venueId])
  @@index([departmentId, isActive])
  @@index([venueId, departmentId, isActive])
  @@index([venueId, name])
}

model CustomerDepartmentTippingSetting {
  id                     String         @id @default(cuid())
  customerId             String
  revenueCentreType      RevenueCentreType
  qrTippingEnabled       Boolean        @default(false)
  teamTippingEnabled     Boolean        @default(true)
  individualTippingEnabled Boolean      @default(false)
  shiftSelectorEnabled   Boolean        @default(false)
  customer               Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@unique([customerId, revenueCentreType])
  @@index([customerId, qrTippingEnabled])
}

model StaffMember {
  id                 String               @id @default(cuid())
  customerId         String
  venueId            String
  staffCode          String?
  externalPayrollRef String?
  externalSystemRef  String?
  externalSystemProvider IntegrationProvider?
  firstName          String
  lastName           String
  displayName        String?
  email              String?
  payrollReference   String?
  status             StaffStatus          @default(ACTIVE)
  employmentStartAt  DateTime?
  employmentEndAt    DateTime?
  customer           Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue              Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  departmentAssignments DepartmentStaffAssignment[]
  shiftAssignments      ShiftStaffAssignment[]
  qrAssets              QrAsset[]
  poolMemberships    PoolMember[]
  poolHoursEntries   PoolHoursEntry[]
  poolDistributionAllocations PoolDistributionAllocation[]
  importedHoursWorked ImportedHoursWorked[]
  importedServiceCharges ImportedServiceCharge[]
  payrollExportLines PayrollExportLine[]
  allocationLines    AllocationRuleLine[] @relation("AllocationLineStaffRecipient")
  allocationResults  AllocationResult[]
  tipOutPostings     TipOutPosting[]
  destinationTipTransactions TipTransaction[] @relation("TipDestinationEmployee")
  auditLogs          AuditLog[]             @relation("AuditStaffMember")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([customerId, status])
  @@index([venueId, status])
  @@index([venueId, lastName, firstName])
  @@unique([customerId, staffCode])
  @@unique([venueId, email])
  @@index([externalSystemProvider, externalSystemRef])
}

model DepartmentStaffAssignment {
  id            String      @id @default(cuid())
  customerId    String
  venueId       String
  departmentId  String
  staffMemberId String
  isPrimary     Boolean     @default(false)
  isActive      Boolean     @default(true)
  activeFrom    DateTime    @default(now())
  activeTo      DateTime?
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue         Venue       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  department    Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([departmentId, staffMemberId])
  @@index([customerId, venueId])
  @@index([departmentId, isActive])
  @@index([staffMemberId, isActive])
}

model QrAsset {
  id                String                 @id @default(cuid())
  customerId        String
  venueId           String
  departmentId      String?
  serviceAreaId     String?
  staffMemberId     String?
  slug              String                 @unique
  destinationType   QrAssetDestinationType
  label             String
  printName         String
  displayMode       DisplayMode
  isActive          Boolean                @default(true)
  previewConfig     Json?
  customer          Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue             Venue                  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  department        Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  serviceArea       ServiceArea?           @relation(fields: [serviceAreaId], references: [id], onDelete: SetNull)
  staffMember       StaffMember?           @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([customerId, venueId, departmentId])
  @@index([venueId, displayMode, isActive])
  @@index([departmentId, isActive])
  @@index([serviceAreaId])
  @@index([staffMemberId])
  @@index([destinationType, isActive])
}

model Shift {
  id            String       @id @default(cuid())
  customerId    String
  venueId       String
  departmentId  String
  name          String
  timezone      String
  startsAt      DateTime
  endsAt        DateTime
  status        ShiftStatus  @default(SCHEDULED)
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue         Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  department    Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  staffAssignments ShiftStaffAssignment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([customerId, venueId])
  @@index([departmentId, status, startsAt, endsAt])
  @@index([venueId, status, startsAt, endsAt])
}

model ShiftStaffAssignment {
  id               String      @id @default(cuid())
  shiftId          String
  staffMemberId    String
  role             String
  eligibleForTips  Boolean     @default(true)
  shift            Shift       @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  staffMember      StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([shiftId, staffMemberId])
  @@index([shiftId, eligibleForTips])
  @@index([staffMemberId, eligibleForTips])
}

model Pool {
  id                 String               @id @default(cuid())
  customerId         String
  venueId            String
  name               String
  slug               String
  description        String?
  poolType           PoolType             @default(HYBRID)
  status             PoolStatus           @default(ACTIVE)
  venue              Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  customer           Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  members            PoolMember[]
  hoursEntries       PoolHoursEntry[]
  distributionRuns   PoolDistributionRun[]
  distributionAllocations PoolDistributionAllocation[]
  allocationLines    AllocationRuleLine[] @relation("AllocationLinePoolRecipient")
  allocationResults  AllocationResult[]
  tipOutRules        TipOutRule[]
  tipOutPostings     TipOutPosting[]
  destinationTipTransactions TipTransaction[] @relation("TipDestinationPool")
  auditLogs          AuditLog[]             @relation("AuditPool")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@unique([venueId, slug])
  @@index([customerId, status])
  @@index([customerId, poolType, status])
  @@index([venueId, status])
  @@index([venueId, poolType, status])
}

model PoolMember {
  id             String       @id @default(cuid())
  poolId         String
  staffMemberId  String
  isActive       Boolean      @default(true)
  joinedAt       DateTime     @default(now())
  leftAt         DateTime?
  pool           Pool         @relation(fields: [poolId], references: [id], onDelete: Cascade)
  staffMember    StaffMember  @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  /// Keep membership history instead of deleting rows so allocations can be reconstructed for a past period.
  @@unique([poolId, staffMemberId])
  @@index([poolId, isActive, joinedAt])
  @@index([staffMemberId, isActive])
}

model AllocationRule {
  id              String               @id @default(cuid())
  venueId         String
  departmentId    String?
  serviceAreaId   String?
  templateId      String?
  scope           AllocationRuleScope  @default(VENUE_DEFAULT)
  selectionType   TipSelectionType?
  name            String
  description     String?
  priority        Int                  @default(100)
  isActive        Boolean              @default(true)
  effectiveFrom   DateTime?
  effectiveTo     DateTime?
  venue           Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  department      Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  serviceArea     ServiceArea?         @relation(fields: [serviceAreaId], references: [id], onDelete: SetNull)
  template        AllocationRuleTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  lines           AllocationRuleLine[]
  auditLogs       AuditLog[]          @relation("AuditAllocationRule")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  /// The application layer should ensure only one active rule wins for a given destination and date window.
  @@index([venueId, isActive, priority])
  @@index([templateId])
  @@index([serviceAreaId, selectionType, isActive, priority])
  @@index([departmentId, selectionType, isActive, priority])
  @@index([venueId, effectiveFrom, effectiveTo])
  @@index([name])
}

model AllocationRuleTemplate {
  id            String               @id @default(cuid())
  slug          String               @unique
  name          String
  description   String?
  scope         AllocationRuleScope  @default(VENUE_DEFAULT)
  selectionType TipSelectionType?
  priority      Int                  @default(100)
  isActive      Boolean              @default(true)
  isRecommended Boolean              @default(true)
  lines         AllocationRuleTemplateLine[]
  rules         AllocationRule[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([isActive, isRecommended])
  @@index([scope, selectionType])
  @@index([name])
}

model AllocationRuleTemplateLine {
  id                         String                   @id @default(cuid())
  allocationRuleTemplateId   String
  recipientType              AllocationRecipientType
  percentageBps              Int
  sortOrder                  Int                      @default(0)
  allocationRuleTemplate     AllocationRuleTemplate   @relation(fields: [allocationRuleTemplateId], references: [id], onDelete: Cascade)
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt

  @@index([allocationRuleTemplateId, sortOrder])
  @@index([recipientType])
}

model AllocationRuleLine {
  id                String                   @id @default(cuid())
  allocationRuleId  String
  recipientType     AllocationRecipientType
  staffMemberId     String?
  poolId            String?
  percentageBps     Int
  sortOrder         Int                      @default(0)
  allocationRule    AllocationRule           @relation(fields: [allocationRuleId], references: [id], onDelete: Cascade)
  staffMember       StaffMember?             @relation("AllocationLineStaffRecipient", fields: [staffMemberId], references: [id], onDelete: SetNull)
  pool              Pool?                    @relation("AllocationLinePoolRecipient", fields: [poolId], references: [id], onDelete: SetNull)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  /// Business rule: line percentages should total 10_000 basis points per allocation rule.
  @@index([allocationRuleId, sortOrder])
  @@index([recipientType])
  @@index([staffMemberId])
  @@index([poolId])
}

model PayrollConfig {
  id                 String            @id @default(cuid())
  customerId         String            @unique
  frequency          PayrollFrequency
  settlementFrequency SettlementFrequency @default(WEEKLY)
  payPeriodAnchor    DateTime?
  settlementDay      Int?
  exportEmail        String?
  notes              String?
  payrollCalendarId  String?
  customer           Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  payrollCalendar    PayrollCalendar?  @relation(fields: [payrollCalendarId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  /// One payroll configuration per customer keeps reporting and settlement schedules deterministic.
  @@index([frequency])
}

model PayrollCalendar {
  id              String          @id @default(cuid())
  customerId      String          @unique
  startDate       DateTime
  startDayOfWeek  Int
  periodsPerYear  Int             @default(13)
  periodLengthDays Int            @default(28)
  timezone        String          @default("Europe/London")
  customer        Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  payrollConfigs  PayrollConfig[]
  payrollPeriods  PayrollPeriod[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([startDate])
  @@index([customerId, startDate])
}

model PayrollPeriod {
  id                String            @id @default(cuid())
  customerId        String
  payrollCalendarId String?
  externalSystemRef String?
  externalSystemProvider IntegrationProvider?
  frequency         PayrollFrequency
  label             String?
  year              Int
  periodNumber      Int
  startDate         DateTime
  endDate           DateTime
  startsAt          DateTime
  endsAt            DateTime
  customer          Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  payrollCalendar   PayrollCalendar?  @relation(fields: [payrollCalendarId], references: [id], onDelete: SetNull)
  payrollExportBatches PayrollExportBatch[]
  tipTransactions   TipTransaction[]
  allocationResults AllocationResult[]
  poolHoursEntries  PoolHoursEntry[]
  poolDistributionRuns PoolDistributionRun[]
  poolDistributionAllocations PoolDistributionAllocation[]
  tipOutPostings    TipOutPosting[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([customerId, startsAt, endsAt])
  @@unique([customerId, year, periodNumber])
  @@index([customerId, startsAt])
  @@index([customerId, endsAt])
  @@index([customerId, startDate])
  @@index([customerId, endDate])
  @@index([payrollCalendarId, startDate])
  @@index([externalSystemProvider, externalSystemRef])
}

model PoolHoursEntry {
  id              String               @id @default(cuid())
  customerId      String
  venueId         String
  poolId          String
  payrollPeriodId String
  employeeId      String
  hoursWorked     Decimal              @db.Decimal(8, 4)
  source          PoolHoursEntrySource @default(MANUAL)
  status          PoolHoursEntryStatus @default(DRAFT)
  createdBy       String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  customer        Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue           Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  pool            Pool                 @relation(fields: [poolId], references: [id], onDelete: Cascade)
  payrollPeriod   PayrollPeriod        @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  employee        StaffMember          @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([poolId, payrollPeriodId, employeeId])
  @@index([customerId, payrollPeriodId])
  @@index([venueId, poolId, payrollPeriodId])
  @@index([employeeId, payrollPeriodId])
  @@index([poolId, status])
}

model PoolDistributionRun {
  id                 String                    @id @default(cuid())
  customerId         String
  venueId            String
  poolId             String
  payrollPeriodId    String
  poolTotal          Decimal                   @db.Decimal(10, 2)
  totalHours         Decimal                   @db.Decimal(10, 4)
  perHourRate        Decimal                   @db.Decimal(12, 8)
  roundingAdjustment Decimal                   @db.Decimal(10, 2) @default(0)
  status             PoolDistributionRunStatus @default(DRAFT)
  createdBy          String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  customer           Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue              Venue                     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  pool               Pool                      @relation(fields: [poolId], references: [id], onDelete: Cascade)
  payrollPeriod      PayrollPeriod             @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  allocations        PoolDistributionAllocation[]

  @@unique([poolId, payrollPeriodId])
  @@index([customerId, payrollPeriodId, status])
  @@index([venueId, poolId, status])
  @@index([payrollPeriodId, status])
}

model PoolDistributionAllocation {
  id                String               @id @default(cuid())
  customerId        String
  venueId           String
  poolId            String
  payrollPeriodId   String
  runId             String
  employeeId        String
  hoursWorked       Decimal              @db.Decimal(8, 4)
  allocationAmount  Decimal              @db.Decimal(10, 2)
  hoursSource       PoolHoursEntrySource @default(MANUAL)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  customer          Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue             Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  pool              Pool                 @relation(fields: [poolId], references: [id], onDelete: Cascade)
  payrollPeriod     PayrollPeriod        @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  run               PoolDistributionRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  employee          StaffMember          @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([runId, employeeId])
  @@index([customerId, payrollPeriodId])
  @@index([venueId, poolId, payrollPeriodId])
  @@index([employeeId, payrollPeriodId])
}

model ImportedHoursWorked {
  id                String                @id @default(cuid())
  customerId        String
  venueId           String
  departmentId      String?
  staffMemberId     String?
  integrationProvider IntegrationProvider
  externalRecordRef String
  sourceSystemName  String?
  status            IntegrationSyncStatus @default(PENDING)
  workDate          DateTime
  shiftStartsAt     DateTime?
  shiftEndsAt       DateTime?
  hoursWorked       Decimal               @db.Decimal(8, 2)
  rawPayload        Json?
  importedAt        DateTime              @default(now())
  customer          Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  venue             Venue                 @relation(fields: [venueId], references: [id], onDelete: Cascade)
  department        Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  staffMember       StaffMember?          @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([integrationProvider, externalRecordRef])
  @@index([customerId, workDate])
  @@index([venueId, workDate])
  @@index([departmentId, workDate])
  @@index([staffMemberId, workDate])
  @@index([status, importedAt])
}

model ImportedServiceCharge {
